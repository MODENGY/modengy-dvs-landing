---
/* Плавающая карточка «Как вам покрытие?»: выезжает слева на середине прокрутки.
   Звёзды подсвечиваются при наведении, клик → реальная страница отзывов MODENGY.
   Крестик закрывает карточку. Логика показа/скрытия — motion.ts → buildReviewCard. */
const reviewsUrl = 'https://modengy.ru/surveys/';
---

<div
  data-review-card
  class="review-float fixed bottom-5 left-5 z-40 hidden w-[266px] overflow-hidden rounded-2xl border border-lined bg-bg1/95 shadow-2xl backdrop-blur-md sm:block"
>
  <span class="glow-soft pointer-events-none absolute -right-8 -top-8 h-28 w-28 opacity-60"></span>

  <!-- закрыть -->
  <button
    type="button"
    data-review-close
    aria-label="Закрыть"
    class="absolute right-2 top-2 z-10 flex h-7 w-7 items-center justify-center rounded-full border border-lined bg-bg0/70 text-mutd transition-colors hover:border-white/30 hover:text-white"
  >
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
  </button>

  <a href={reviewsUrl} target="_blank" rel="noopener" data-review-link
    class="group relative block p-4 pr-9" aria-label="Оставить отзыв о покрытии MODENGY">
    <div class="flex items-center gap-2.5">
      <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-accent text-bg0">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20 2H4a2 2 0 00-2 2v18l4-4h14a2 2 0 002-2V4a2 2 0 00-2-2zM7 9h10v2H7V9zm6 4H7v-2h6v2z"/></svg>
      </span>
      <div class="leading-tight">
        <div class="text-[14.5px] font-semibold text-white">Пользуетесь MODENGY?</div>
        <div class="text-[12px] text-mutd">Поделитесь опытом с покрытием</div>
      </div>
    </div>

    <div class="mt-3.5 flex gap-1.5" role="img" aria-label="Оценка покрытия">
      {Array.from({ length: 5 }).map(() => (
        <span data-star class="review-star text-white/20 transition-colors duration-150">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </span>
      ))}
    </div>

    <div class="mt-3 flex items-center justify-between">
      <span class="font-mono text-[11px] uppercase tracking-[0.06em] text-mutd">5.0 · 105 отзывов</span>
      <span class="inline-flex items-center gap-1 text-[12.5px] font-semibold text-accent">
        Оставить отзыв
        <span class="transition-transform group-hover:translate-x-0.5">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </span>
      </span>
    </div>
  </a>
</div>

<style>
  .review-float { transition: box-shadow .3s ease; }
  .review-float:hover { box-shadow: 0 22px 55px -14px rgba(253,193,0, .3); }
  .review-star { cursor: pointer; }
  .review-star.lit { color: #fdc100; transform: scale(1.08); }
</style>
