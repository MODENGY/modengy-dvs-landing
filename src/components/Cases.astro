---
/* Кейсы «до/после» — горизонтальная лента.
   Десктоп: секция пинится, лента едет справа→налево, большой баллон летит
   поверх и поворачивается по оси Y (motion.ts → buildCasesFly).
   Мобайл: нативный свайп (scroll-snap), без баллона. */
import Icon from './Icon.astro';
interface Case { slug: string; title: string; desc: string }
interface Props { cases: Case[]; base: string }
const { cases, base } = Astro.props;
const img = (n: string) => `${base}img/${n}`;
---

<section data-cases class="grain relative overflow-hidden bg-bg0 text-white">
  <!-- Большой летящий баллон (fixed-оверлей, только десктоп). perspective — для 3D-поворота по Y -->
  <div class="fly-overlay pointer-events-none fixed inset-0 hidden overflow-hidden opacity-0 lg:block"
    style="z-index:80" aria-hidden="true">
    <div data-can-glow class="glow-soft absolute left-0 top-1/2 h-[62vh] w-[62vh] opacity-0"></div>
    <canvas data-can3d class="fly-can absolute left-0 top-1/2 h-[58vh] w-[58vh] xl:h-[62vh] xl:w-[62vh]"></canvas>
  </div>

  <!-- Шапка -->
  <div class="relative z-10 mx-auto max-w-[1280px] px-5 pt-24 md:px-8 md:pt-32">
    <span class="sec-tag sec-tag--dark" data-reveal>Кейсы</span>
    <h2 class="mt-5 max-w-3xl text-[clamp(28px,3.4vw,44px)]" data-split>До и после нанесения MODENGY</h2>
    <p class="mt-4 max-w-2xl text-mutd" data-reveal>
      Реальные узлы двигателя: слева — деталь без покрытия, справа — с антифрикционным покрытием MODENGY.
      <span class="whitespace-nowrap text-white/50">Листайте&nbsp;→</span>
    </p>
  </div>

  <!-- Лента кейсов -->
  <div class="relative z-10 mt-12 pb-24 md:mt-16 md:pb-28">
    <div data-cases-track
      class="flex snap-x snap-mandatory gap-5 overflow-x-auto px-5 pb-4 md:gap-8 md:px-8 lg:snap-none lg:overflow-visible lg:pb-0">
      {cases.map((c, i) => (
        <article data-case class="group shrink-0 snap-center w-[86vw] sm:w-[66vw] lg:w-[50vw] xl:w-[43vw]">
          <div class="case-card grid gap-6 rounded-[20px] border border-lined bg-bg1 p-5 md:grid-cols-[1.1fr_1fr] md:p-7">
            <!-- пара до/после -->
            <div class="grid grid-cols-2 gap-3">
              <figure>
                <figcaption class="mb-2 flex items-center gap-2 font-mono text-[10.5px] uppercase tracking-[0.08em] text-mutd">
                  <span class="h-0.5 w-5 rounded bg-white/30"></span> До
                </figcaption>
                <div class="overflow-hidden rounded-[12px] border border-lined bg-bg0">
                  <img src={img(`case-${c.slug}-before.webp`)} alt={`${c.title} — до нанесения MODENGY`}
                    loading="lazy" decoding="async" class="aspect-square w-full object-cover" />
                </div>
              </figure>
              <figure>
                <figcaption class="mb-2 flex items-center gap-2 font-mono text-[10.5px] uppercase tracking-[0.08em] text-accent">
                  <span class="h-0.5 w-5 rounded bg-accent"></span> После
                </figcaption>
                <div class="overflow-hidden rounded-[12px] border border-accent/40 bg-bg0">
                  <img src={img(`case-${c.slug}-after.webp`)} alt={`${c.title} — после нанесения MODENGY`}
                    loading="lazy" decoding="async" class="aspect-square w-full object-cover" />
                </div>
              </figure>
            </div>
            <!-- текст -->
            <div class="flex flex-col justify-center">
              <div class="font-mono text-[12px] uppercase tracking-[0.08em] text-accent">
                Кейс {String(i + 1).padStart(2, '0')} / {String(cases.length).padStart(2, '0')}
              </div>
              <h3 class="mt-2 font-display text-xl font-semibold md:text-2xl">{c.title}</h3>
              <p class="mt-3 text-[14.5px] leading-relaxed text-mutd">{c.desc}</p>
              <a href="#quiz" class="mt-5 inline-flex items-center gap-2 font-semibold text-accent transition-transform hover:gap-3">
                Подобрать под этот узел <Icon name="arrow-right" size={16} />
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .case-card {
    transition: transform .35s ease, border-color .35s ease, box-shadow .35s ease;
  }
  article:hover .case-card {
    transform: translateY(-6px);
    border-color: rgba(255, 180, 0, .45);
    box-shadow: 0 24px 60px -22px rgba(255, 180, 0, .18);
  }
</style>
