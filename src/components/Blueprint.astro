---
/* SIGNATURE: интерактивный чертёж-разрез ДВС (честный line-art, не реализм).
   6 хотспотов ↔ 6 карточек узлов. Hover/клик по точке подсвечивает контур
   и карточку; hover по карточке подсвечивает точку. Логика — motion.ts (buildBlueprint). */
import Icon from './Icon.astro';

interface App { slug: string; title: string; text: string; product: string }
interface Props { applications: App[]; base: string }
const { applications, base } = Astro.props;
const useImg = (i: number) => `${base}img/use${i + 1}.webp`;

/* Позиции хотспотов на чертеже (viewBox 0 0 560 640) */
const HOTSPOTS: Record<string, { x: number; y: number }> = {
  zaslonki: { x: 96, y: 150 },   // дроссельная заслонка во впуске
  klapany: { x: 212, y: 148 },   // стержень впускного клапана
  krepezh: { x: 372, y: 118 },   // болт ГБЦ
  porshni: { x: 191, y: 318 },   // юбка поршня
  vkladyshi: { x: 250, y: 408 }, // вкладыш нижней головки шатуна
  shlicy: { x: 432, y: 486 },    // шлицевой хвостовик коленвала
};
---

<section id="applications" class="blueprint-grid grain relative overflow-hidden bg-bg0 py-24 text-white md:py-32">
  <div class="relative mx-auto max-w-[1280px] px-5 md:px-8">
    <span class="sec-tag sec-tag--dark" data-reveal>Применение</span>
    <h2 class="mt-5 max-w-3xl text-[clamp(28px,3.4vw,44px)]" data-reveal>Где применяется в двигателе</h2>
    <p class="mt-4 max-w-xl text-mutd" data-reveal>
      Наведите на точку чертежа или карточку узла. Клик — переход к подбору покрытия под этот узел.
    </p>

    <div class="mt-14 grid items-start gap-12 lg:grid-cols-[1.15fr_1fr]" data-blueprint>
      <!-- ЧЕРТЁЖ -->
      <figure class="relative" data-reveal>
        <svg viewBox="0 0 560 640" class="w-full" role="img"
          aria-label="Технический разрез двигателя внутреннего сгорания с отмеченными узлами применения покрытия MODENGY">
          <defs>
            <!-- штриховка металла в разрезе -->
            <pattern id="bp-hatch" width="7" height="7" patternTransform="rotate(45)" patternUnits="userSpaceOnUse">
              <line x1="0" y1="0" x2="0" y2="7" stroke="rgba(221,233,239,0.26)" stroke-width="1" />
            </pattern>
            <!-- зона покрытия MODENGY -->
            <pattern id="bp-coat" width="5" height="5" patternTransform="rotate(45)" patternUnits="userSpaceOnUse">
              <line x1="0" y1="0" x2="0" y2="5" stroke="rgba(253,193,0,0.55)" stroke-width="1.4" />
            </pattern>
          </defs>

          <!-- рамка чертежа -->
          <rect x="8" y="8" width="544" height="624" class="bp-stroke" opacity="0.4" />
          <line x1="8" y1="596" x2="552" y2="596" class="bp-stroke" opacity="0.4" />
          <g font-family="Gilroy, sans-serif" font-size="10.5" fill="rgba(221,233,239,0.42)" letter-spacing="1.1">
            <text x="24" y="618">MODENGY · РАЗРЕЗ ДВС · СХЕМА УЗЛОВ</text>
            <text x="470" y="618">М 1:1</text>
          </g>

          <!-- ================= ВПУСК + ДРОССЕЛЬНАЯ ЗАСЛОНКА ================= -->
          <g class="bp-part" data-part="zaslonki">
            <path class="bp-stroke" d="M150 122 H68 a16 16 0 0 0 -16 16 v24 a16 16 0 0 0 16 16 H150" />
            <circle class="bp-stroke" cx="96" cy="150" r="4" />
            <line class="bp-stroke" x1="76" y1="166" x2="116" y2="134" stroke-width="2.8" />
            <text x="52" y="196" font-family="Gilroy, sans-serif" font-size="9.5"
              fill="rgba(221,233,239,0.4)" letter-spacing="0.8">ВПУСК</text>
          </g>

          <!-- выпускной канал -->
          <path class="bp-stroke" d="M392 122 H474 a16 16 0 0 1 16 16 v24 a16 16 0 0 1 -16 16 H392" opacity="0.75" />
          <text x="446" y="196" font-family="Gilroy, sans-serif" font-size="9.5"
            fill="rgba(221,233,239,0.4)" letter-spacing="0.8">ВЫПУСК</text>

          <!-- ================= ГОЛОВКА БЛОКА ЦИЛИНДРОВ ================= -->
          <path class="bp-stroke" d="M150 84 H392 a10 10 0 0 1 10 10 V196 H140 V94 a10 10 0 0 1 10 -10 Z"
            fill="url(#bp-hatch)" />
          <!-- камера сгорания (шатёр) -->
          <path class="bp-stroke" d="M196 196 L226 172 H316 L346 196" fill="#0e1a20" />
          <!-- распредвалы -->
          <circle class="bp-stroke" cx="212" cy="112" r="19" />
          <path class="bp-stroke" d="M212 93 a19 19 0 0 1 13 5 l-13 14 Z" />
          <circle class="bp-stroke" cx="330" cy="112" r="19" />
          <path class="bp-stroke" d="M330 93 a19 19 0 0 1 13 5 l-13 14 Z" />

          <!-- клапаны: стержни, пружины, тарелки -->
          <g class="bp-part" data-part="klapany">
            <path class="bp-stroke" d="M212 131 V181 M330 131 V181" stroke-width="2.6" />
            <!-- витки пружин -->
            <path class="bp-stroke" opacity="0.8"
              d="M201 136 L223 143 L201 150 L223 157 L201 164 L223 171 L201 178" />
            <path class="bp-stroke" opacity="0.8"
              d="M319 136 L341 143 L319 150 L341 157 L319 164 L341 171 L319 178" />
            <!-- тарелки клапанов -->
            <path class="bp-stroke" d="M197 180 h30 l-9 10 h-12 Z M315 180 h30 l-9 10 h-12 Z" />
          </g>

          <!-- болты ГБЦ -->
          <g class="bp-part" data-part="krepezh">
            <path class="bp-stroke" d="M164 84 h16 v10 h-16 Z M172 94 V212 M362 84 h16 v10 h-16 Z M370 94 V212" />
            <path class="bp-stroke" opacity="0.6" d="M167 100 h10 M167 108 h10 M365 100 h10 M365 108 h10" />
          </g>

          <!-- прокладка ГБЦ -->
          <line class="bp-stroke" x1="140" y1="199" x2="402" y2="199" stroke-dasharray="6 4" />

          <!-- ================= БЛОК ЦИЛИНДРОВ ================= -->
          <path class="bp-stroke" d="M140 202 H402 V470 H140 Z" fill="url(#bp-hatch)" />
          <!-- зеркало цилиндра (полость) -->
          <rect x="196" y="202" width="150" height="238" fill="#0e1a20" class="bp-stroke" />
          <!-- рубашка охлаждения -->
          <path class="bp-stroke" opacity="0.5" d="M170 214 V430 M176 214 V430 M366 214 V430 M372 214 V430" />

          <!-- ================= ПОРШЕНЬ ================= -->
          <g class="bp-part" data-part="porshni">
            <!-- днище + канавки колец -->
            <path class="bp-stroke" d="M199 232 H343 V262 H199 Z" fill="url(#bp-hatch)" />
            <path class="bp-stroke" d="M199 268 H343 M199 276 H343 M199 284 H343" />
            <!-- юбка (зона покрытия) -->
            <path d="M199 288 H343 V352 q-72 14 -144 0 Z" fill="url(#bp-coat)" stroke="#fdc100" stroke-width="1.6" />
            <!-- бобышка и палец -->
            <circle class="bp-stroke" cx="271" cy="300" r="17" fill="#0e1a20" />
            <circle class="bp-stroke" cx="271" cy="300" r="9" />
          </g>

          <!-- ================= ШАТУН + ВКЛАДЫШИ ================= -->
          <g class="bp-part" data-part="vkladyshi">
            <!-- стержень (двутавр) -->
            <path class="bp-stroke" d="M259 316 L253 386 M283 316 L289 386" />
            <path class="bp-stroke" opacity="0.45" d="M266 322 L262 384 M276 322 L280 384" />
            <!-- нижняя головка + вкладыш -->
            <circle class="bp-stroke" cx="271" cy="408" r="34" fill="#0e1a20" />
            <circle cx="271" cy="408" r="26" fill="none" stroke="#fdc100" stroke-width="4" opacity="0.9" />
            <circle class="bp-stroke" cx="271" cy="408" r="21" />
            <!-- крышка шатуна -->
            <path class="bp-stroke" opacity="0.6" d="M237 408 H305" />
          </g>

          <!-- ================= КОЛЕНВАЛ ================= -->
          <!-- щёки и противовес -->
          <path class="bp-stroke" d="M271 408 L271 494" opacity="0.5" />
          <path class="bp-stroke" d="M225 494 a46 46 0 0 0 92 0 a46 46 0 0 0 -92 0" fill="url(#bp-hatch)" />
          <circle class="bp-stroke" cx="271" cy="494" r="24" fill="#0e1a20" />
          <circle class="bp-stroke" cx="271" cy="494" r="9" />
          <path class="bp-stroke" opacity="0.5" d="M247 536 a46 46 0 0 0 48 0" />

          <!-- ================= ШЛИЦЕВОЙ ХВОСТОВИК ================= -->
          <g class="bp-part" data-part="shlicy">
            <path class="bp-stroke" d="M317 478 H500 M317 510 H500 M500 470 V518" />
            <path class="bp-stroke" opacity="0.75"
              d="M392 478 V510 M406 478 V510 M420 478 V510 M434 478 V510 M448 478 V510 M462 478 V510 M476 478 V510 M490 478 V510" />
          </g>

          <!-- ================= ПОДДОН ================= -->
          <path class="bp-stroke" d="M140 470 H402 L378 556 H164 Z" />
          <line class="bp-stroke" x1="176" y1="530" x2="366" y2="530" stroke-dasharray="7 5" opacity="0.55" />

          <!-- ================= ВЫНОСКИ ================= -->
          <g font-family="Gilroy, sans-serif" font-size="11" letter-spacing="0.6">
            <path class="callout-line" d="M343 320 H432" />
            <circle class="callout-dot" cx="343" cy="320" r="2.6" />
            <text x="438" y="324" fill="rgba(221,233,239,0.55)">ЮБКА · 15–25 МКМ</text>
            <path class="callout-line" d="M305 424 H432" />
            <circle class="callout-dot" cx="305" cy="424" r="2.6" />
            <text x="438" y="428" fill="rgba(221,233,239,0.55)">MoS₂ + ГРАФИТ</text>
            <path class="callout-line" d="M330 131 H432" />
            <circle class="callout-dot" cx="330" cy="131" r="2.6" />
            <text x="438" y="135" fill="rgba(221,233,239,0.55)">ШТОК КЛАПАНА</text>
          </g>

          <!-- хотспоты -->
          {applications.map((a) => {
            const p = HOTSPOTS[a.slug];
            if (!p) return null;
            return (
              <a href="#buy" class="bp-hotspot" data-hotspot={a.slug} aria-label={a.title}>
                <circle class="halo" cx={p.x} cy={p.y} r="10" />
                <circle class="core" cx={p.x} cy={p.y} r="5.5" />
              </a>
            );
          })}
        </svg>
      </figure>

      <!-- КАРТОЧКИ УЗЛОВ -->
      <div class="grid gap-3">
        {applications.map((a, i) => (
          <a href="#buy" data-app-card={a.slug} data-reveal
            class="app-card group flex items-center gap-4 p-4">
            <img transition:name={`app-${a.slug}`} src={useImg(i)} alt={a.title} loading="lazy" decoding="async"
              width="56" height="56" class="kenburns h-14 w-14 shrink-0 rounded-full border border-lined object-cover" />
            <div class="min-w-0 flex-1">
              <h3 class="text-[15.5px] font-semibold text-white">{a.title}</h3>
              <p class="mt-0.5 truncate text-[13px] text-mutd">{a.text}</p>
              <span class="mt-1 inline-block font-mono text-[11px] uppercase tracking-[0.08em] text-accent">{a.product}</span>
            </div>
            <span class="text-accent transition-transform group-hover:translate-x-1">
              <Icon name="arrow-right" size={18} />
            </span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
