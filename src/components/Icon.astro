---
/* Единый набор stroke-иконок (24×24, stroke 1.5, round caps).
   Один стиль на весь сайт — никаких эмодзи и текстовых символов. */
interface Props { name: string; class?: string; size?: number }
const { name, class: cls = '', size = 24 } = Astro.props;

const ICONS: Record<string, string> = {
  // пламя — задиры при холодном пуске
  flame: '<path d="M12 3c.5 2.2 1.9 3.6 3.2 5 1.2 1.3 1.8 2.7 1.8 4.5a5 5 0 0 1-10 0c0-1.6.8-2.8 1.7-3.9C10 7.2 11.4 5.6 12 3Z"/><path d="M12 13.5c.9.9.9 2.3 0 3.2"/>',
  // манометр — износ и потеря КПД
  gauge: '<path d="M4 15a8 8 0 1 1 16 0"/><path d="m12 15 3.6-3.6"/><circle cx="12" cy="15" r="1.4"/>',
  // термометр — экстремальные температуры
  thermometer: '<path d="M14 4v10.54a4 4 0 1 1-4 0V4a2 2 0 0 1 4 0Z"/>',
  // волны — шум и вибрация
  waves: '<path d="M3 9c1.5 0 1.5 1.8 3 1.8S7.5 9 9 9s1.5 1.8 3 1.8S13.5 9 15 9s1.5 1.8 3 1.8S19.5 9 21 9"/><path d="M3 15c1.5 0 1.5 1.8 3 1.8S7.5 15 9 15s1.5 1.8 3 1.8S13.5 15 15 15s1.5 1.8 3 1.8S19.5 15 21 15"/>',
  // завод — производство полного цикла
  factory: '<path d="M3 21V9.5l5.5 3.5v-3.5l5.5 3.5V4a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1v17H3Z"/><path d="M7 17h2M11.5 17h2M16 17h2"/>',
  // колба — лаборатории
  flask: '<path d="M9.5 3h5M10.5 3v5.8l-5.1 8.9A2 2 0 0 0 7.1 21h9.8a2 2 0 0 0 1.7-3.3l-5.1-8.9V3"/><path d="M7.6 15h8.8"/>',
  // глобус — отрасли
  globe: '<circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3a14.5 14.5 0 0 1 0 18M12 3a14.5 14.5 0 0 0 0 18"/>',
  // обмен — импортозамещение
  swap: '<path d="M4 8h13l-3.2-3.2M20 16H7l3.2 3.2"/>',
  // шестерня — сопровождение/технология
  cog: '<circle cx="12" cy="12" r="3.2"/><path d="M12 2.5v2.6M12 18.9v2.6M2.5 12h2.6M18.9 12h2.6M5.3 5.3l1.8 1.8M16.9 16.9l1.8 1.8M18.7 5.3l-1.8 1.8M7.1 16.9l-1.8 1.8"/>',
  // пин — география
  pin: '<path d="M12 21.5S5 15.6 5 10a7 7 0 0 1 14 0c0 5.6-7 11.5-7 11.5Z"/><circle cx="12" cy="10" r="2.4"/>',
  // телефон
  phone: '<path d="M21 16.9v2.1a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.4 19.4 0 0 1-6-6A19.8 19.8 0 0 1 1.1 3.2 2 2 0 0 1 3.1 1h2.1a2 2 0 0 1 2 1.7c.1 1 .4 1.9.7 2.8a2 2 0 0 1-.5 2.1L6.3 8.7a16 16 0 0 0 6 6l1.1-1.1a2 2 0 0 1 2.1-.5c.9.3 1.8.6 2.8.7a2 2 0 0 1 1.7 2.1Z"/>',
  // звезда — рейтинг
  star: '<path d="m12 3.5 2.5 5.2 5.7.8-4.1 4 1 5.7-5.1-2.7-5.1 2.7 1-5.7-4.1-4 5.7-.8Z"/>',
  // документ — ТУ
  doc: '<path d="M14.5 2.5H6a2 2 0 0 0-2 2v15a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14.5 2.5V8H20M8.5 13h7M8.5 17h7"/>',
  // слои — MoS₂
  layers: '<path d="M12 3.5 3 8l9 4.5L21 8l-9-4.5Z"/><path d="m3 13 9 4.5 9-4.5"/>',
  // таймер — сроки
  timer: '<circle cx="12" cy="13.5" r="7.5"/><path d="M12 10v3.8l2.4 2.4M9.5 2.5h5"/>',
  // щит — защита/гарантии
  shield: '<path d="M12 2.5 4.5 5.4v5.9c0 4.8 3.1 8.4 7.5 9.7 4.4-1.3 7.5-4.9 7.5-9.7V5.4L12 2.5Z"/><path d="m8.8 11.8 2.2 2.2 4.2-4.2"/>',
  // коробка — линейка/поставка
  box: '<path d="M21 8 12 3 3 8v8l9 5 9-5V8Z"/><path d="m3 8 9 5 9-5M12 13v8"/>',
  // стрелка
  'arrow-right': '<path d="M4.5 12h15m-6.5-6.5L19.5 12 13 18.5"/>',
  // галочка
  check: '<path d="m5 12.5 4.5 4.5L19 7.5"/>',
  // загрузка
  download: '<path d="M12 3.5v11.5m-5-5 5 5 5-5"/><path d="M4.5 20.5h15"/>',
};

const html = ICONS[name] ?? ICONS['cog'];
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  class={cls}
  set:html={html}
/>
