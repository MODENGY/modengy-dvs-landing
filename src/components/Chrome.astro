---
/* Обвязка посадочной: фиксированный чёрный хедер (без меню сайта — только якоря),
   мобильная нижняя панель и плавающий CTA (десктоп, после 1.5 экрана). */
import Icon from './Icon.astro';
interface Props { phone: string; phoneHref: string; tg?: string }
const { phone, phoneHref, tg = 'https://t.me/modengy' } = Astro.props;

const anchors = [
  { href: '#problem', label: 'Проблема' },
  { href: '#material', label: 'Покрытие' },
  { href: '#applications', label: 'Применение' },
  { href: '#why', label: 'Почему мы' },
  { href: '#specs', label: 'Показатели' },
];
---

<!-- Хедер: всегда --bg-0, при скролле blur + тонкая линия (класс ставит JS) -->
<header data-header class="fixed inset-x-0 top-0 z-50 bg-bg0 transition-shadow">
  <div class="mx-auto flex h-[var(--header-h)] max-w-[1280px] items-center justify-between px-5 md:px-8">
    <a href="#top" class="block">
      <img src={`${import.meta.env.BASE_URL}img/logo-white.png`} alt="MODENGY" width="150" height="27" class="h-[26px] w-auto" />
    </a>

    <nav class="hidden items-center gap-7 lg:flex" aria-label="Разделы страницы">
      {anchors.map((a) => (
        <a href={a.href} class="text-[14px] font-medium text-mutd transition-colors hover:text-white">{a.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-3 md:gap-5">
      <a href={phoneHref} class="hidden font-mono text-[14px] text-white/85 transition-colors hover:text-accent sm:block">{phone}</a>
      <a href="#quiz" class="btn-accent inline-flex items-center gap-2 px-4 py-2 text-sm">
        Подобрать покрытие
      </a>
    </div>
  </div>
  <div data-header-line class="h-px w-full bg-lined opacity-0 transition-opacity"></div>
  <!-- линия прогресса чтения -->
  <div class="pointer-events-none h-[2px] w-full">
    <div data-rail-fill class="h-full w-0 bg-accent shadow-[0_0_8px_rgba(253,193,0,.6)]"></div>
  </div>
</header>


<!-- Плавающий CTA (десктоп): появляется после 1.5 экрана, прячется у формы -->
<a href="#quiz" data-float-cta class="float-cta btn-accent hidden items-center gap-2 px-5 py-3.5 text-sm shadow-xl md:inline-flex">
  <Icon name="arrow-right" size={17} />
  Подобрать покрытие
</a>

<!-- Мобильная нижняя панель -->
<nav class="fixed inset-x-0 bottom-0 z-50 grid grid-cols-3 border-t border-lined bg-bg0/95 backdrop-blur-md md:hidden" aria-label="Быстрые действия">
  <a href={phoneHref} class="flex flex-col items-center gap-1 py-2.5 text-[11px] font-medium text-mutd">
    <Icon name="phone" size={18} /> Позвонить
  </a>
  <a href={tg} target="_blank" rel="noopener" class="flex flex-col items-center gap-1 border-x border-lined py-2.5 text-[11px] font-medium text-mutd">
    <Icon name="arrow-right" size={18} /> Telegram
  </a>
  <a href="#quiz" class="flex flex-col items-center gap-1 bg-accent py-2.5 text-[11px] font-bold text-bg0">
    <Icon name="check" size={18} /> Подобрать
  </a>
</nav>
