---
import Base from '../../layouts/Base.astro';
import Chrome from '../../components/Chrome.astro';
import BuyKit from '../../components/BuyKit.astro';
import Conveyor from '../../components/Conveyor.astro';
import Blueprint from '../../components/Blueprint.astro';
import Icon from '../../components/Icon.astro';
import VideoCard from '../../components/VideoCard.astro';
import Cases from '../../components/Cases.astro';
import ReviewFloat from '../../components/ReviewFloat.astro';
import { dvs } from '../../data/dvs';

const base = import.meta.env.BASE_URL; // '/promo/'
const img = (name: string) => `${base}img/${name.replace(/\.png$/, '.webp')}`;

const industries = ['Автопром', 'Нефтегаз', 'Авиакосмос', 'ОПК', 'Робототехника', 'ЖД транспорт', 'Металлургия', 'Атомная энергетика'];

/* Паспорт покрытия — только проверенные значения */
const passport = [
  { param: 'Коэффициент трения', value: 'до 0,03', note: 'метод ASTM G99 · собственная лаборатория' },
  { param: 'Толщина плёнки', value: '15–25 мкм', note: '' },
  { param: 'Межслойная сушка', value: '10 мин', note: 'при комнатной температуре' },
  { param: 'Полное отверждение', value: '~12 ч', note: 'при комнатной температуре' },
  { param: 'Отверждение при нагреве', value: '20 мин', note: 'при +170 °C' },
  { param: 'Состав', value: 'MoS₂ + графит, полимерное связующее', note: '' },
  { param: 'Формат', value: 'аэрозоль 210 мл', note: '' },
];

const painIcons = ['flame', 'gauge', 'thermometer', 'waves'];

const why = [
  { icon: 'timer', n: '9', suffix: '+', t: 'лет на рынке', d: 'Самая широкая в РФ линейка серийных антифрикционных твердосмазочных покрытий.', wide: true },
  { icon: 'flask', n: '2', suffix: '', t: 'собственные лаборатории', d: 'R&D и аккредитованные испытания: трение (ASTM G99), износ, коррозия (ISO 9227), резьба (ГОСТ ISO 16047).', wide: false },
  { icon: 'globe', n: '12', suffix: '+', t: 'отраслей применения', d: 'Авиакосмос, ОПК, нефтегаз, робототехника, ЖД, атомная энергетика, металлургия.', wide: false },
  { icon: 'swap', n: '', suffix: '', t: 'Импортозамещение', d: 'Прямые аналоги Molykote и других импортных покрытий — со склада в РФ.', wide: false },
  { icon: 'cog', n: '', suffix: '', t: 'Сопровождение под ключ', d: 'Подбор марки, расчёт расхода, шеф-нанесение и поддержка при внедрении.', wide: false },
];

/* 6 эффектов покрытия (как на исходной странице, но в нашем стиле) */
const effectCards = [
  { icon: 'shield', t: 'Предотвращает задиры', d: 'Аварийная защита при холодном пуске и «масляном голодании».' },
  { icon: 'timer', t: 'Замедляет износ', d: 'Повышает ресурс пары трения и узла в целом.' },
  { icon: 'waves', t: 'Гасит шум и вибрацию', d: 'Стабильный коэффициент трения — тише и ровнее работа.' },
  { icon: 'thermometer', t: 'Держит температуру', d: 'Работает там, где жидкая смазка вымывается или деградирует.' },
  { icon: 'layers', t: 'Не меняет геометрию', d: 'Плёнка 15–25 мкм не влияет на посадку и зазоры.*' },
];
---

<Base
  title="Антифрикционное покрытие для деталей ДВС | MODENGY"
  description="Твердосмазочное антифрикционное покрытие MODENGY для деталей ДВС: юбки поршней, вкладыши, дроссельные заслонки. Снижает трение, задиры и износ. Готовый набор — купить на маркетплейсах."
>
  <link slot="head" rel="preload" as="image" href={img('hero-1.png')} fetchpriority="high" />
  <link slot="head" rel="preload" as="font" type="font/woff" href={`${base}fonts/Gilroy-Regular.woff`} crossorigin />
  <link slot="head" rel="preload" as="font" type="font/woff" href={`${base}fonts/Gilroy-Bold.woff`} crossorigin />

  <Chrome phone={dvs.phone} phoneHref={dvs.phoneHref} />
  <div id="top"></div>

  <!-- ======================= HERO ======================= -->
  <section class="blueprint-grid grain relative overflow-hidden bg-bg0 pt-[var(--header-h)] text-white">
    <div class="glow-soft absolute right-[6%] top-1/3 h-[480px] w-[480px]"></div>

    <div class="relative mx-auto grid max-w-[1280px] items-center gap-12 px-5 pb-24 pt-12 md:grid-cols-2 md:px-8 md:pb-28 md:pt-16">
      <div>
        <span class="inline-flex items-center gap-2 rounded-full border border-lined px-4 py-1.5 font-mono text-[11.5px] uppercase tracking-[0.08em] text-accent">
          <span class="h-1.5 w-1.5 rounded-full bg-accent"></span> {dvs.hero.kicker}
        </span>

        <h1 class="mt-6 text-[clamp(27px,3.15vw,44px)] leading-[1.1]">
          <span class="line"><span>Антифрикционное</span></span>
          <span class="line"><span>покрытие для</span></span>
          <span class="line"><span>деталей <em class="not-italic text-accent">ДВС</em></span></span>
        </h1>

        <p class="mt-6 max-w-xl text-[17px] leading-relaxed text-mutd md:text-lg">{dvs.hero.sub}</p>

        <div class="mt-8 flex flex-col gap-3.5 sm:flex-row">
          <a href="#buy" class="btn-accent group inline-flex items-center justify-center gap-2 px-7 py-4">
            Купить набор
            <span class="transition-transform group-hover:translate-x-1"><Icon name="arrow-right" size={17} /></span>
          </a>
          <a href="#specs" class="btn-ghost-d inline-flex items-center justify-center px-7 py-4 font-medium">
            Характеристики
          </a>
        </div>

        <!-- траст-бейджи -->
        <div class="mt-10 flex flex-wrap gap-2.5">
          <a href="#reviews" class="inline-flex items-center gap-2 rounded-full border border-lined px-3.5 py-2 text-[13px] text-mutd transition-colors hover:border-accent hover:text-white">
            <span class="text-accent"><Icon name="star" size={15} /></span> 5.0 · 105 отзывов <span class="text-white/40">MyReviews</span>
          </a>
          <span class="inline-flex items-center gap-2 rounded-full border border-lined px-3.5 py-2 text-[13px] text-mutd">
            <span class="text-accent"><Icon name="doc" size={15} /></span> Выпускается по ТУ
          </span>
          <span class="inline-flex items-center gap-2 rounded-full border border-lined px-3.5 py-2 text-[13px] text-mutd">
            <span class="text-accent"><Icon name="swap" size={15} /></span> Аналог Molykote · импортозамещение
          </span>
        </div>
      </div>

      <!-- Баллон + чертёжные выноски -->
      <div class="relative mx-auto w-full max-w-[560px]">
        <div class="relative z-10 mx-auto max-w-[420px]">
          <img
            src={img('hero-1.png')}
            alt="Аэрозоль MODENGY 210 мл — антифрикционное твердосмазочное покрытие для деталей ДВС"
            width="420" height="404"
            fetchpriority="high" decoding="async"
            class="w-full drop-shadow-2xl"
          />
        </div>

        <!-- выноски: рисуются при загрузке -->
        <svg class="pointer-events-none absolute inset-0 z-20 hidden md:block" viewBox="0 0 560 520" aria-hidden="true">
          <g font-family="Gilroy, sans-serif" font-size="11" fill="#b5bfc4" letter-spacing="1">
            <text x="6" y="76">ПЛЁНКА 15–25 МКМ</text>
            <text x="6" y="420">MoS₂ + ГРАФИТ</text>
            <text x="432" y="188">ОДНОКРАТНО,</text>
            <text x="432" y="203">НА ВЕСЬ РЕСУРС</text>
          </g>
          <path data-draw-load class="callout-line" d="M128 84 L218 148" />
          <circle class="callout-dot" cx="218" cy="148" r="3" />
          <path data-draw-load class="callout-line" d="M112 408 L208 342" />
          <circle class="callout-dot" cx="208" cy="342" r="3" />
          <path data-draw-load class="callout-line" d="M428 196 L362 238" />
          <circle class="callout-dot" cx="362" cy="238" r="3" />
        </svg>
      </div>
    </div>

    <!-- бегущая строка отраслей -->
    <div class="relative border-y border-lined bg-graphite-900/70 py-3.5" data-marquee>
      <div class="flex w-max gap-10 whitespace-nowrap will-change-transform" data-marquee-track>
        {[...industries, ...industries].map((n) => (
          <span class="flex items-center gap-3 font-mono text-[12px] font-medium uppercase tracking-[0.14em] text-white/40">
            {n} <span class="text-accent">◆</span>
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================= СОЦИАЛЬНОЕ ДОКАЗАТЕЛЬСТВО ======================= -->
  <section class="border-b border-linel bg-surface py-10">
    <div class="mx-auto grid max-w-[1280px] grid-cols-2 gap-8 px-5 md:px-8 lg:grid-cols-4">
      <a href="#reviews" class="flex items-center gap-4 transition-opacity hover:opacity-80" data-reveal>
        <div class="font-mono text-4xl font-medium text-ink">5.0</div>
        <div>
          <div class="flex gap-0.5 text-accent">
            {Array.from({ length: 5 }).map(() => <Icon name="star" size={14} />)}
          </div>
          <div class="mt-1 text-[13px] text-mutl">105 отзывов · MyReviews</div>
        </div>
      </a>
      <div data-reveal>
        <div class="font-mono text-4xl font-medium text-ink">9+</div>
        <div class="mt-1 text-[13px] text-mutl">лет производства покрытий</div>
      </div>
      <div data-reveal>
        <div class="font-mono text-4xl font-medium text-ink">12+</div>
        <div class="mt-1 text-[13px] text-mutl">отраслей: от автопрома до атомной энергетики</div>
      </div>
      <div data-reveal>
        <div class="font-mono text-4xl font-medium text-ink">ТУ</div>
        <div class="mt-1 text-[13px] text-mutl">выпускается по ТУ, протоколы испытаний</div>
      </div>
    </div>
  </section>


  <!-- ======================= ПРОБЛЕМА ======================= -->
  <section id="problem" class="blueprint-grid-l relative overflow-hidden bg-bgl py-24 md:py-32">
    <span class="sheet-index" aria-hidden="true">02</span>
    <div class="relative mx-auto max-w-[1280px] px-5 md:px-8">
      <span class="sec-tag" data-reveal>Проблема</span>
      <h2 class="mt-5 max-w-2xl text-[clamp(28px,3.4vw,44px)]" data-reveal>Что снижает ресурс двигателя</h2>
      <p class="mt-4 max-w-xl text-mutl" data-reveal>Там, где жидкая смазка не справляется, металл работает по металлу. Результат — задиры, износ и потеря мощности.</p>

      <!-- мобайл: свайп со snap; десктоп: сетка -->
      <div class="mt-12 flex snap-x snap-mandatory gap-5 overflow-x-auto pb-4 sm:grid sm:grid-cols-2 sm:overflow-visible sm:pb-0 lg:grid-cols-4">
        {dvs.pains.map((p, i) => (
          <div data-reveal class="card-heat w-[78vw] max-w-[330px] shrink-0 snap-start p-6 sm:w-auto sm:max-w-none">
            <div class="icon-pad mb-5"><Icon name={painIcons[i]} size={22} /></div>
            <h3 class="text-[17px]">{p.title}</h3>
            <p class="mt-2 text-[14.5px] leading-relaxed text-mutl">{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ======================= МАТЕРИАЛ: СУХАЯ СМАЗКА ======================= -->
  <section id="material" class="grain relative overflow-hidden bg-bg1 py-24 text-white md:py-32">
    <div class="relative mx-auto grid max-w-[1280px] items-center gap-14 px-5 md:grid-cols-2 md:px-8">
      <div>
        <span class="sec-tag sec-tag--dark" data-reveal>Материал</span>
        <p class="mt-5 text-[16.5px] leading-relaxed text-mutd" data-reveal>{dvs.how.lead}</p>

        <!-- состав — чипы -->
        <div class="mt-6 flex flex-wrap gap-2.5" data-reveal="left">
          {['MoS₂', 'Графит', 'Полимерное связующее', 'Плёнка 15–25 мкм'].map((c) => (
            <span class="inline-flex rounded-full border border-accent/40 bg-accent/[0.06] px-3.5 py-1.5 font-mono text-[12px] uppercase tracking-[0.06em] text-accent">{c}</span>
          ))}
        </div>

        <div class="mt-6 flex flex-wrap gap-3">
          <a href="#buy" class="btn-accent inline-flex items-center gap-2 px-6 py-3.5">
            Купить набор <Icon name="arrow-right" size={16} />
          </a>
        </div>

        <!-- температурная линейка: рабочий диапазон набора для ДВС -->
        <div class="mt-10" data-reveal="right">
          <div class="mb-2 flex justify-between font-mono text-[11px] uppercase tracking-[0.08em] text-mutd">
            <span>−100 °C</span><span>Рабочая зона · MODENGY Для деталей ДВС</span><span>+300 °C</span>
          </div>
          <div class="relative h-3 overflow-hidden rounded-full bg-lined">
            <!-- зона −70…+260 из диапазона −100…+300 → left 7.5%, width 82.5% -->
            <div class="temp-zone absolute inset-y-0 rounded-full border border-accent/60" style="left:7.5%;width:82.5%"></div>
          </div>
          <div class="mt-2 flex gap-4 font-mono text-[12px] uppercase tracking-[0.08em] text-accent">
            <span>от <span data-count="-70" data-suffix=" °C">0</span></span>
            <span>до <span data-count="260" data-suffix=" °C">0</span></span>
          </div>
        </div>
      </div>

      <!-- Справа: слои MoS₂ + ИНТЕРАКТИВНЫЙ 3D-баллон (крути мышкой) -->
      <div class="relative">
        <figure data-mos data-reveal="left" class="card-d relative overflow-hidden p-8">
          <svg viewBox="0 0 360 220" class="w-full" role="img" aria-label="Слоистая структура дисульфида молибдена: пластины скользят друг по другу">
            {[0, 1, 2, 3, 4, 5].map((i) => (
              <g class="mos-layer" data-mos-i={i}>
                <path
                  d={`M${60} ${180 - i * 26} l190 0 l40 -14 l-190 0 Z`}
                  fill={i % 2 ? 'rgba(253,193,0,0.14)' : 'rgba(255,255,255,0.05)'}
                  stroke={i % 2 ? 'rgba(253,193,0,0.55)' : 'rgba(255,255,255,0.22)'}
                  stroke-width="1.2"
                />
              </g>
            ))}
            <g font-family="Gilroy, sans-serif" font-size="10.5" fill="#b5bfc4" letter-spacing="1">
              <text x="60" y="210">СЛОИ MoS₂ СКОЛЬЗЯТ ДРУГ ПО ДРУГУ</text>
            </g>
          </svg>
        </figure>

        <img src={img('prod-dvs.png')} alt="Набор MODENGY для деталей ДВС"
          loading="lazy" decoding="async" width="300" height="300" data-reveal
          class="mx-auto mt-8 w-full max-w-[300px] drop-shadow-2xl" />
      </div>
    </div>

    <!-- эффекты покрытия -->
    <div class="relative mx-auto mt-16 grid max-w-[1280px] gap-5 px-5 sm:grid-cols-2 md:px-8 lg:grid-cols-3">
      {effectCards.map((c) => (
        <div data-reveal class="card-d p-6">
          <div class="flex h-11 w-11 items-center justify-center rounded-xl border border-lined text-accent"><Icon name={c.icon} size={22} /></div>
          <h3 class="mt-4 text-[16px] text-white">{c.t}</h3>
          <p class="mt-1.5 text-[14px] leading-relaxed text-mutd">{c.d}</p>
        </div>
      ))}
    </div>
    <p class="relative mx-auto mt-5 max-w-[1280px] px-5 text-[13px] leading-relaxed text-mutd md:px-8" data-reveal>
      * После нанесения покрытия в узле должен быть сохранён зазор, установленный заводом-производителем.
    </p>
  </section>

  <!-- ======================= ПАСПОРТ ПОКРЫТИЯ ======================= -->
  <section id="specs" class="blueprint-grid-l relative overflow-hidden bg-surface py-24 md:py-32">
    <span class="sheet-index" aria-hidden="true">01</span>
    <div class="relative mx-auto max-w-[1280px] px-5 md:px-8">
      <span class="sec-tag" data-reveal>Паспорт покрытия</span>

      <div class="mt-10 grid items-start gap-14 lg:grid-cols-[1fr_440px]">
        <div>
          {passport.map((row) => (
            <div class="grid grid-cols-[1fr_auto] items-baseline gap-6 border-b border-linel py-5" data-reveal>
              <div>
                <div class="font-medium text-ink">{row.param}</div>
                {row.note && <div class="mt-0.5 font-mono text-[12px] uppercase tracking-[0.06em] text-mutl">{row.note}</div>}
              </div>
              <div class="text-right font-mono text-xl font-medium text-ink md:text-2xl">{row.value}</div>
            </div>
          ))}
          <p class="mt-4 font-mono text-[12px] uppercase tracking-[0.06em] text-mutl">
            Значения по ТУ производителя · протоколы испытаний — по запросу
          </p>
        </div>

        <figure data-reveal class="rounded-[16px] border border-linel bg-bgl p-6 md:p-7">
          <svg viewBox="0 0 420 240" fill="none" class="w-full" role="img" aria-label="Схема снижения коэффициента трения после нанесения покрытия">
            <g stroke="#dde9ef" stroke-width="1">
              <line x1="30" y1="16" x2="30" y2="210" />
              <line x1="30" y1="210" x2="405" y2="210" />
              <line x1="30" y1="68" x2="405" y2="68" stroke-dasharray="3 5" />
              <line x1="30" y1="176" x2="405" y2="176" stroke-dasharray="3 5" />
            </g>
            <path d="M30 52 C 130 48, 260 60, 400 55" stroke="#b5bfc4" stroke-width="2" stroke-dasharray="6 6" />
            <path d="M30 60 C 150 66, 210 164, 400 178" stroke="#fdc100" stroke-width="3.5" stroke-linecap="round" />
            <circle cx="400" cy="178" r="5" fill="#fdc100" />
            <g font-family="Gilroy, sans-serif" font-size="11" letter-spacing="0.5">
              <text x="36" y="44" fill="#5b6f78">μ БЕЗ ПОКРЫТИЯ</text>
              <text x="222" y="150" fill="#0e1a20" font-weight="600">С ПОКРЫТИЕМ MODENGY</text>
              <text x="342" y="205" fill="var(--color-ink)" font-weight="600">ДО 0,03</text>
            </g>
          </svg>
          <figcaption class="mt-3 font-mono text-[11.5px] uppercase tracking-[0.06em] text-mutl">
            Схема · коэффициент трения до и после нанесения
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ======================= ПРИМЕНЕНИЕ: ЧЕРТЁЖ (SIGNATURE) ======================= -->
  <Blueprint applications={dvs.applications} base={base} />



  <!-- ======================= ПОЧЕМУ MODENGY (bento) ======================= -->
  <section id="why" class="blueprint-grid-l relative overflow-hidden bg-bgl py-24 md:py-32">
    <span class="sheet-index" aria-hidden="true">05</span>
    <div class="relative mx-auto max-w-[1280px] px-5 md:px-8">
      <span class="sec-tag" data-reveal>Производитель</span>
      <h2 class="mt-5 max-w-2xl text-[clamp(28px,3.4vw,44px)]" data-reveal>Почему выбирают MODENGY?</h2>
      <p class="mt-4 max-w-xl text-mutl" data-reveal>Не перекупщики и не «гаражная» химия — производитель полного цикла с собственной наукой и испытаниями.</p>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {why.map((c) => (
          <div data-reveal class={`rounded-[16px] border border-linel bg-surface p-7 ${c.wide ? 'sm:col-span-2' : ''}`}>
            <div class="flex items-start justify-between gap-4">
              <div class="icon-pad"><Icon name={c.icon} size={22} /></div>
              {c.n && (
                <div class="font-mono text-4xl font-medium text-ink md:text-5xl">
                  <span data-count={c.n} data-suffix={c.suffix}>0</span>
                </div>
              )}
            </div>
            <h3 class="mt-5 text-[17px]">{c.t}</h3>
            <p class="mt-2 text-[14.5px] leading-relaxed text-mutl">{c.d}</p>
          </div>
        ))}

        <!-- ячейка-карта: завод и филиал -->
        <div data-reveal class="rounded-[16px] border border-linel bg-bg0 p-7 text-white">
          <div class="flex items-start justify-between">
            <div class="icon-pad !border-lined !text-white"><Icon name="factory" size={22} /></div>
          </div>
          <svg viewBox="0 0 220 120" class="mt-4 w-full" role="img" aria-label="Схема: производство в Брянске, филиал в Санкт-Петербурге">
            <g fill="rgba(255,255,255,0.12)">
              {Array.from({ length: 60 }).map((_, i) => (
                <circle cx={12 + (i % 12) * 18} cy={12 + Math.floor(i / 12) * 22} r="1.3" />
              ))}
            </g>
            <path d="M76 34 L118 86" stroke="#fdc100" stroke-width="1.2" stroke-dasharray="4 4" />
            <circle cx="76" cy="34" r="4" fill="#fdc100" />
            <circle cx="118" cy="86" r="4" fill="#fdc100" />
            <g font-family="Gilroy, sans-serif" font-size="10" fill="#b5bfc4" letter-spacing="0.5">
              <text x="86" y="32">САНКТ-ПЕТЕРБУРГ</text>
              <text x="128" y="90">БРЯНСК · ЗАВОД</text>
            </g>
          </svg>
