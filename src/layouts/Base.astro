---
import { ClientRouter } from 'astro:transitions';
/* Типографика — корпоративный Gilroy (локальные @font-face в theme.css) */
import '../styles/theme.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Антифрикционные твердосмазочные покрытия MODENGY — снижение трения, износа и коррозии. Подбор покрытия под ваш узел за 1 рабочий день.',
  ogImage = '/promo/og-default.jpg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta name="theme-color" content="#0e1a20" />
    <link rel="icon" href="/promo/favicon.ico" sizes="any" />
    <slot name="head" />
    <ClientRouter />
  </head>
  <body>
    <slot />

    <!-- Motion island: подключается после контента, не блокирует первый кадр -->
    <script>
      import '../scripts/motion';
    </script>

    <!-- Яндекс.Метрика (плейсхолдер — вставить реальный ID перед запуском) -->
    <!--
    <script type="text/javascript">
      (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
      m[i].l=1*new Date();k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
      (window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");
      ym(XXXXXX, "init", { clickmap:true, trackLinks:true, accurateTrackBounce:true, webvisor:true });
    </script>
    -->
  </body>
</html>
